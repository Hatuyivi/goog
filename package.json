{
  "name": "numsum",
  "version": "1.1.0",
  "description": "Menu bar calculator — sum numbers from screen selection (API or local OCR) + floor plan room recognizer",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --publish never"
  },
  "build": {
    "appId": "com.numsum.app",
    "productName": "numsum",
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "extraMetadata": {
      "main": "src/main.js"
    }
  },
  "dependencies": {
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
